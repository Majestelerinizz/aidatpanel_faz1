# AidatPanel - Environment Variables Template
# Bu dosyayı .env olarak kopyalayıp kendi değerlerini gir

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=4200
NODE_ENV=development

# ==========================================
# DATABASE (Neon PostgreSQL)
# ==========================================
# Neon.tech'den aldığın connection string
DATABASE_URL="postgresql://neondb_owner:npg_hSPyUNVF3uQ0@ep-green-rice-a4l8eu7b-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Güçlü secret key üret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here

# Token süreleri (saniye cinsinden, opsiyonel - default: 15dk/30gün)
# JWT_EXPIRES_IN=900
# REFRESH_TOKEN_EXPIRES_IN=2592000

# ==========================================
# OPTIONAL: THIRD PARTY SERVICES (Phase 2+)
# ==========================================

# Email Service - Resend
# RESEND_API_KEY=re_xxxxxxxx

# Firebase Push Notifications
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Twilio SMS/WhatsApp
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_FROM=+1xxxxxxxx

# RevenueCat Subscription Validation
# REVENUECAT_API_KEY=rg_xxxxxxxx
# REVENUECAT_WEBHOOK_SECRET=whsec_xxxxxxxx

# ==========================================
# NOTES
# ==========================================
# - Asla gerçek .env dosyasını GitHub'a push etme!
# - .gitignore'da .env zaten ignore ediliyor
# - Üretim ortamında (production) farklı değerler kullan
